
---

# 🚫 .gitignore

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Django
*.log
local_settings.py
db.sqlite3
media/

# Virtual Environment
venv/
env/
ENV/

# VS Code
.vscode/

# PyCharm
.idea/

# Mac
.DS_Store

# Windows
Thumbs.db

# Environment variables
.env

# Migrations (optional)
**/migrations/*.pyc
**/migrations/__pycache__/

# Static files (optional)
staticfiles/

# Coverage
.coverage
htmlcov/

# pytest
.pytest_cache/

# Node modules (if using Node.js for frontend)
node_modules/